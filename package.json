{
  "name": "gymflow-saas",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "launcher": "node launcher.js",
    "launcher:open": "node launcher.js",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "db:studio": "cd packages/database && npx prisma studio"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@prisma/client": "^5.22.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@swc/helpers": "^0.5.13",
    "lodash": "^4.18.1",
    "next": "^14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  }
}
