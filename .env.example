# ─────────────────────────────────────────────
# GymFlow SaaS — Environment Variables
# Copy to .env in each app/package that needs it
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/gymflow_dev"

# ── JWT ───────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── API ───────────────────────────────────────
API_PORT=4000
API_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (SendGrid) ──────────────────────────
SENDGRID_API_KEY="SG...."
EMAIL_FROM="noreply@gymflow.com"
EMAIL_FROM_NAME="GymFlow"

# ── Email (SMTP / Gmail) ──────────────────────
# For Gmail, use an App Password (not your normal password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-16-char-app-password"
# Optional aliases (supported by the app):
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# ── SMS (Twilio) ──────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM_NUMBER="+1..."

# ── Redis ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── AWS S3 ────────────────────────────────────
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="eu-west-1"
AWS_S3_BUCKET="gymflow-uploads"

# ── App ───────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
